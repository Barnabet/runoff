{
  "name": "runoff",
  "private": true,
  "scripts": {
    "dev": "RUNOFF_DB=$PWD/data/runoff.db RUNOFF_FILES_DIR=$PWD/data/files concurrently -n web,worker \"pnpm --filter web dev\" \"pnpm --filter worker dev\"",
    "test": "vitest run --passWithNoTests",
    "seed": "tsx scripts/seed.ts",
    "eval": "tsx scripts/eval.ts"
  },
  "dependencies": {
    "@runoff/core": "workspace:*",
    "@runoff/engine": "workspace:*",
    "openai": "^5.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
